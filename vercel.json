{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": "public",
  "framework": null,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/news.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=1800, stale-while-revalidate=3600" }
      ]
    }
  ]
}
